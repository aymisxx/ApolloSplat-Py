# ============================================================
# ApolloSplat-Py .gitattributes
# Text normalization + binary handling
# Notebook-first Apollo 17 photogrammetry + Gaussian Splatting
# ============================================================


# ============================================================
# Default text normalization
# ============================================================

* text=auto


# ============================================================
# Source code
# ============================================================

*.py text
*.sh text eol=lf
*.bash text eol=lf
*.zsh text eol=lf


# ============================================================
# Jupyter notebooks
# ============================================================

*.ipynb text


# ============================================================
# Markdown / documentation / config
# ============================================================

*.md text
*.rst text
*.txt text
*.yml text
*.yaml text
*.json text
*.toml text
*.ini text
*.cfg text
*.csv text
*.tsv text
*.xml text
*.urdf text
*.xacro text
*.launch text


# ============================================================
# Images
# ============================================================

*.png binary
*.jpg binary
*.jpeg binary
*.bmp binary
*.gif binary
*.webp binary
*.tif binary
*.tiff binary
*.exr binary
*.hdr binary


# ============================================================
# 3D assets / meshes
# ============================================================

*.ply binary
*.obj binary
*.stl binary
*.dae binary
*.fbx binary
*.glb binary
*.gltf binary
*.usd binary
*.usdz binary
*.mtl text


# ============================================================
# COLMAP / SfM / reconstruction files
# ============================================================

*.db binary
*.bin binary


# ============================================================
# Gaussian Splatting files
# ============================================================

*.splat binary
*.ksplat binary


