# ============================================================
# ApolloSplat-Py .gitignore
# Notebook-first Apollo 17 photogrammetry + Gaussian Splatting
# Mesh export + ROS2 / RViz2 visualization
# ============================================================


# ============================================================
# Python bytecode / compiled files
# ============================================================

__pycache__/
*.py[cod]
*$py.class
*.so


# ============================================================
# Python packaging / build artifacts
# ============================================================

.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST


# ============================================================
# PyInstaller
# ============================================================

*.manifest
*.spec


# ============================================================
# Installer logs
# ============================================================

pip-log.txt
pip-delete-this-directory.txt


